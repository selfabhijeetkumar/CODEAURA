# ── Server Config ──
PORT=8080
NODE_ENV=development

# ── Gemini Keys (Auto-rotation) ──
GEMINI_API_KEY=your_primary_gemini_key
ALT_GEMINI_API_KEY=your_backup_gemini_key

# ── OpenRouter Keys (NVIDIA / GPT-OSS / Failover) ──
# Supported Models: Nemotron 3 Super, GPT-OSS 120b, Nemotron 3 Nano, GPT-OSS 20b
NEMOTRON_3_SUPER_API_KEY=your_openrouter_key
GPT_OSS_120B_API_KEY=your_openrouter_key
NEMOTRON_3_NANO_API_KEY=your_openrouter_key
OPENROUTER_API_KEY=your_openrouter_key

# ── Groq Keys (Ultra-fast failover) ──
GROQ_API_KEY=your_groq_api_key

# ── Database (Supabase) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-key

# ── Fallbacks & Legacy ──
DEEPSEEK_API_KEY=your_deepseek_key
STABILITY_API_KEY=your_stability_key_for_images

# ── CORS ──
CORS_ORIGIN=http://localhost:3000
